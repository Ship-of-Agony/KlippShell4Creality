<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <android.webkit.WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <LinearLayout
        android:id="@+id/layoutOsd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="24dp">
            <TextView
                android:id="@+id/tvOsdExtruder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvOsdBed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvOsdChamberSensor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvOsdChamberHeater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvOsdFanModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvOsdFanAux"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvOsdFanChamber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvOsdProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1976D2"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />
            <TextView
                android:id="@+id/tvOsdTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutWebButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWebMenu"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="≡"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            app:backgroundTint="#424242"
            app:cornerRadius="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWebToggle"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="⇄"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            app:backgroundTint="#424242"
            android:layout_marginStart="16dp"
            app:cornerRadius="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWebClose"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="✖"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:backgroundTint="#E53935"
            android:layout_marginStart="16dp"
            app:cornerRadius="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layoutScreensaver"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <ImageView
            android:id="@+id/ivScreensaverLogo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/klippshell_logo_new"
            android:alpha="0.45" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>