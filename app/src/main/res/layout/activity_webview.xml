<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:focusable="true"
        android:nextFocusDown="@+id/btnWebToggle"
        android:scrollbarSize="16dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarTrackVertical="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/panelControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnWebBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="◀"
            android:textSize="20sp"
            android:backgroundTint="#B3000000"
            android:textColor="#FFFFFF"
            app:cornerRadius="24dp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnWebRatio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⛶"
            android:textSize="20sp"
            android:backgroundTint="#B3000000"
            android:textColor="#FFFFFF"
            app:cornerRadius="24dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnWebToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⇄"
            android:textSize="20sp"
            android:backgroundTint="#B3000000"
            android:textColor="#FFFFFF"
            app:cornerRadius="24dp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnWebClose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✖"
            android:textSize="20sp"
            android:backgroundTint="#B3E53935"
            android:textColor="#FFFFFF"
            app:cornerRadius="24dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>