<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:scrollbars="none"
    android:overScrollMode="never"
    android:background="?android:attr/windowBackground"
    tools:ignore="MergeRootFrame">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteEstop"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/report_off_24"
            app:iconSize="20dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#D32F2F"
            app:cornerRadius="22dp"
            app:strokeWidth="1dp"
            app:strokeColor="#40FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/etTargetTvIp"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_pill_input"
            android:backgroundTint="@color/pill_normal_inactive"
            android:hint="TV IP"
            android:inputType="text"
            android:digits="0123456789."
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteEstop"
            app:layout_constraintEnd_toStartOf="@+id/btnSearchTv"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteEstop"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteEstop" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchTv"
            style="@style/Widget.Material3.Button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/broadcast_on_home_24"
            app:iconSize="18dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="22dp"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteEstop"
            app:layout_constraintEnd_toStartOf="@+id/btnLeaveRemote"
            app:layout_constraintStart_toEndOf="@+id/etTargetTvIp"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteEstop" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeaveRemote"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/mobile_hand_off_24"
            app:iconSize="18dp"
            app:iconTint="#D32F2F"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#00000000"
            app:cornerRadius="22dp"
            app:strokeWidth="2dp"
            app:strokeColor="#D32F2F"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteEstop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteEstop" />

        <TextView
            android:id="@+id/tvRemoteStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/remote_status_disconnected"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etTargetTvIp" />

        <FrameLayout
            android:id="@+id/morphingFrameContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            app:layout_constraintDimensionRatio="4:3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvRemoteStatus"
            app:layout_constraintWidth_percent="0.65">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutDpadZone"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_dpad_outer"
                android:backgroundTint="@color/pill_normal_inactive"
                android:padding="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoteOk"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:text="OK"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:elevation="8dp"
                    app:backgroundTint="#424242"
                    app:strokeWidth="2dp"
                    app:strokeColor="#616161"
                    app:cornerRadius="35dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoteUp"
                    android:layout_width="64dp"
                    android:layout_height="50dp"
                    android:text="▲"
                    android:textColor="#424242"
                    android:textSize="18sp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="0dp"
                    app:layout_constraintBottom_toTopOf="@+id/btnRemoteOk"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoteDown"
                    android:layout_width="64dp"
                    android:layout_height="50dp"
                    android:text="▼"
                    android:textColor="#424242"
                    android:textSize="18sp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnRemoteOk" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoteLeft"
                    android:layout_width="50dp"
                    android:layout_height="64dp"
                    android:text="◀"
                    android:textColor="#424242"
                    android:textSize="18sp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btnRemoteOk"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoteRight"
                    android:layout_width="50dp"
                    android:layout_height="64dp"
                    android:text="▶"
                    android:textColor="#424242"
                    android:textSize="18sp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/btnRemoteOk"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <FrameLayout
                android:id="@+id/layoutTouchZone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/viewTouchPadField"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/touchme"
                    android:tint="#808080"
                    android:scaleType="fitCenter"
                    android:padding="90dp"
                    android:clickable="true"
                    android:focusable="true"
                    tools:ignore="UseAppTint" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical"
                    android:weightSum="3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTouchBack"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:layout_marginEnd="4dp"
                        android:text="←"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#2196F3"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTouchReturnDpad"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.8"
                        android:layout_marginEnd="4dp"
                        android:layout_marginStart="4dp"
                        android:text="✥"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#D32F2F"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTouchOk"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:layout_marginStart="4dp"
                        android:text="ok"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#4CAF50"
                        app:cornerRadius="24dp" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleTouchMode"
            android:layout_width="54dp"
            android:layout_height="32dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="6dp"
            app:icon="@drawable/ic_trackpad_mouse"
            app:iconSize="18dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="@+id/morphingFrameContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/morphingFrameContainer"
            app:layout_constraintTop_toTopOf="@+id/morphingFrameContainer"
            app:layout_constraintVertical_bias="0.5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteStream"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/media_link_24"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="20dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoteLayout"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="@+id/morphingFrameContainer"
            app:layout_constraintTop_toBottomOf="@+id/morphingFrameContainer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteLayout"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/picture_in_picture_alt_24"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="20dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteStream"
            app:layout_constraintEnd_toEndOf="@+id/morphingFrameContainer"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteStream"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteStream" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBar"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="4dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/credit_card_24"
            app:iconSize="20dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="19dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/btnRemotePip"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="@+id/morphingFrameContainer"
            app:layout_constraintTop_toBottomOf="@+id/btnRemoteStream" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemotePip"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/subtitles_24"
            app:iconSize="20dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="19dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteBar"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoteBox"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteBar"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteBar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBox"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/view_compact_alt_24"
            app:iconSize="20dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="19dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteBar"
            app:layout_constraintEnd_toEndOf="@+id/morphingFrameContainer"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/btnRemotePip"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteBar" />

        <TextView
            android:id="@+id/tvSecDpadTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="On-Screen Display OSD"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnRemoteBar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteZoomIn"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/zoom_out_24"
            app:iconSize="18dp"
            app:iconTint="?android:attr/textColorPrimary"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/pill_normal_inactive"
            app:cornerRadius="19dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/secDpadContainer"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="@+id/morphingFrameContainer"
            app:layout_constraintTop_toBottomOf="@+id/tvSecDpadTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteHome"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="6dp"
            app:icon="@drawable/home_app_logo_24"
            app:iconSize="20dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#E53935"
            app:cornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="@+id/btnRemoteZoomIn"
            app:layout_constraintStart_toStartOf="@+id/btnRemoteZoomIn"
            app:layout_constraintTop_toBottomOf="@+id/btnRemoteZoomIn" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/secDpadContainer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_dpad_outer"
            android:backgroundTint="@color/pill_normal_inactive"
            android:alpha="0.95"
            android:padding="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteHome"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoteZoomOut"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteZoomIn"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteZoomIn">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecUp"
                android:layout_width="30dp"
                android:layout_height="26dp"
                android:text="▲"
                android:textColor="#424242"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#00000000"
                app:cornerRadius="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecDown"
                android:layout_width="30dp"
                android:layout_height="26dp"
                android:text="▼"
                android:textColor="#424242"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#00000000"
                app:cornerRadius="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecLeft"
                android:layout_width="26dp"
                android:layout_height="30dp"
                android:text="◀"
                android:textColor="#424242"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#00000000"
                app:cornerRadius="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecRight"
                android:layout_width="26dp"
                android:layout_height="30dp"
                android:text="▶"
                android:textColor="#424242"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#00000000"
                app:cornerRadius="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteZoomOut"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/zoom_in_24"
            app:iconSize="18dp"
            app:iconTint="?android:attr/textColorPrimary"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/pill_normal_inactive"
            app:cornerRadius="19dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            app:layout_constraintEnd_toEndOf="@+id/morphingFrameContainer"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/secDpadContainer"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteZoomIn" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteCamera"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/developer_mode_tv_24"
            app:iconSize="20dp"
            app:iconTint="?android:attr/textColorPrimary"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/pill_normal_inactive"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            app:layout_constraintEnd_toEndOf="@+id/btnRemoteZoomOut"
            app:layout_constraintStart_toStartOf="@+id/btnRemoteZoomOut"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteHome" />

        <TextView
            android:id="@+id/tvFooterInfo"
