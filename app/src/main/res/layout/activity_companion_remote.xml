<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/containerIpBox"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_remote_card"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnRemoteEStop"
        app:layout_constraintVertical_chainStyle="spread">

        <EditText
            android:id="@+id/etTargetTvIp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:hint="z.B. 192.168.178.109 (TV IP)"
            android:textColorHint="#888888"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:digits="0123456789."
            android:imeOptions="actionDone"/>

        <ImageView
            android:id="@+id/btnSearchTv"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="6dp"
            android:src="@drawable/ic_search"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRemoteEStop"
        android:layout_width="72dp"
        android:layout_height="44dp"
        android:text="@string/remote_btn_estop"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:backgroundTint="#E53935"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1dp"
        app:cornerRadius="10dp"
        app:layout_constraintTop_toBottomOf="@id/containerIpBox"
        app:layout_constraintBottom_toTopOf="@+id/frameDpadContainer"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLeaveRemote"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="✕"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:backgroundTint="?attr/colorCardControl"
        app:strokeColor="?android:attr/textColorPrimary"
        app:strokeWidth="1dp"
        app:shapeAppearanceOverlay="@style/CircleButtonOverlay"
        app:layout_constraintTop_toTopOf="@id/btnRemoteEStop"
        app:layout_constraintBottom_toBottomOf="@id/btnRemoteEStop"
        app:layout_constraintEnd_toEndOf="parent"/>

    <FrameLayout
        android:id="@+id/frameDpadContainer"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_dpad_container_circle"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnRemoteEStop"
        app:layout_constraintBottom_toTopOf="@+id/btnRemoteZoomIn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panelMainDpad"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_dpad_outer">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteOk"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:text="OK"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#424242"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="1dp"
                app:shapeAppearanceOverlay="@style/CircleButtonOverlay"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteUp"
                android:layout_width="46dp"
                android:layout_height="38dp"
                android:text="●"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@android:color/transparent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteDown"
                android:layout_width="46dp"
                android:layout_height="38dp"
                android:text="●"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@android:color/transparent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteLeft"
                android:layout_width="38dp"
                android:layout_height="46dp"
                android:text="●"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                app:backgroundTint="@android:color/transparent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteRight"
                android:layout_width="38dp"
                android:layout_height="46dp"
                android:text="●"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                app:backgroundTint="@android:color/transparent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRemoteZoomIn"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="zoom (-)"
        android:textSize="11sp"
        android:textColor="?android:attr/textColorPrimary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="?attr/colorCardControl"
        app:strokeColor="?android:attr/textColorPrimary"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/frameDpadContainer"
        app:layout_constraintBottom_toTopOf="@+id/containerMiddleRow"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRemoteZoomOut"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="zoom +"
        android:textSize="11sp"
        android:textColor="?android:attr/textColorPrimary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="?attr/colorCardControl"
        app:strokeColor="?android:attr/textColorPrimary"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/frameDpadContainer"
        app:layout_constraintBottom_toTopOf="@+id/containerMiddleRow"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/containerMiddleRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/btnRemoteZoomIn"
        app:layout_constraintBottom_toTopOf="@+id/containerComplexActions">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Klipper OS"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="?attr/colorCardControl"
            app:strokeColor="#2979FF"
            app:strokeWidth="1.5dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemotePip"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="OSD"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="?attr/colorCardControl"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteStream"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Video Stream"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="?attr/colorCardControl"
            app:strokeColor="#00E676"
            app:strokeWidth="1.5dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerComplexActions"
        android:layout_width="match_parent"
        android:layout_height="145dp"
        android:padding="6dp"
        android:background="@drawable/bg_remote_card_no_border"
        app:layout_constraintTop_toBottomOf="@id/containerMiddleRow"
        app:layout_constraintBottom_toTopOf="@+id/containerBottomRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBar"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:text="@string/remote_btn_bar"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:cornerRadius="24dp"
            app:strokeWidth="1dp"
            app:strokeColor="?android:attr/textColorPrimary"
            app:backgroundTint="?attr/colorCardControl"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBox"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:text="@string/remote_btn_box"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:cornerRadius="24dp"
            app:strokeWidth="1dp"
            app:strokeColor="?android:attr/textColorPrimary"
            app:backgroundTint="?attr/colorCardControl"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/viewOsdCircleBg"
            android:layout_width="122dp"
            android:layout_height="122dp"
            android:background="@drawable/bg_osd_sub_circle"
            app:layout_constraintTop_toTopOf="@id/btnRemoteSecUp"
            app:layout_constraintBottom_toBottomOf="@id/btnRemoteSecDown"
            app:layout_constraintStart_toStartOf="@id/btnRemoteSecLeft"
            app:layout_constraintEnd_toEndOf="@id/btnRemoteSecRight"/>

        <TextView
            android:id="@+id/tvOsdCenterLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OSD"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnRemoteBar"
            app:layout_constraintEnd_toStartOf="@id/btnRemoteBox"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteSecUp"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="▲"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@android:color/transparent"
            app:shapeAppearanceOverlay="@style/CircleButtonOverlay"
            app:layout_constraintBottom_toTopOf="@id/tvOsdCenterLabel"
            app:layout_constraintStart_toStartOf="@id/tvOsdCenterLabel"
            app:layout_constraintEnd_toEndOf="@id/tvOsdCenterLabel"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteSecDown"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="▼"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@android:color/transparent"
            app:shapeAppearanceOverlay="@style/CircleButtonOverlay"
            app:layout_constraintTop_toBottomOf="@id/tvOsdCenterLabel"
            app:layout_constraintStart_toStartOf="@id/tvOsdCenterLabel"
            app:layout_constraintEnd_toEndOf="@id/tvOsdCenterLabel"
            android:layout_marginTop="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteSecLeft"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="◀"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="12sp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            app:backgroundTint="@android:color/transparent"
            app:shapeAppearanceOverlay="@style/CircleButtonOverlay"
            app:layout_constraintEnd_toStartOf="@id/tvOsdCenterLabel"
            app:layout_constraintTop_toTopOf="@id/tvOsdCenterLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvOsdCenterLabel"
            android:layout_marginEnd="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteSecRight"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="▶"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="12sp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            app:backgroundTint="@android:color/transparent"
            app:shapeAppearanceOverlay="@style/CircleButtonOverlay"
            app:layout_constraintStart_toEndOf="@id/tvOsdCenterLabel"
            app:layout_constraintTop_toTopOf="@id/tvOsdCenterLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvOsdCenterLabel"
            android:layout_marginStart="12dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/containerBottomRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/containerComplexActions"
        app:layout_constraintBottom_toTopOf="@+id/tvRemoteStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteLight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/remote_btn_light"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="?attr/colorCardControl"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBack"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_home"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="#FFFFFF"
            app:backgroundTint="#E53935"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteCamera"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/remote_btn_camera"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="?attr/colorCardControl"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvRemoteStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Getrennt"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/containerBottomRow"
        app:layout_constraintBottom_toTopOf="@+id/tvFooterInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvFooterInfo"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_remote_card"
        android:gravity="center"
        android:text="@string/remote_no_printer_connected"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvRemoteStatus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>