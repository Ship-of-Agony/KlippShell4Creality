<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:background="?android:attr/windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <EditText
            android:id="@+id/etTargetTvIp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_pill_input"
            android:backgroundTint="@color/pill_normal_inactive"
            android:hint="192.168.178.106"
            android:inputType="text"
            android:digits="0123456789."
            android:padding="14dp"
            android:gravity="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@+id/btnSearchTv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchTv"
            style="@style/Widget.Material3.Button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/broadcast_on_home_24"
            app:iconSize="24dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="28dp"
            app:layout_constraintBottom_toBottomOf="@+id/etTargetTvIp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/etTargetTvIp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteEstop"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="6dp"
            app:icon="@drawable/report_off_24"
            app:iconSize="26dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#D32F2F"
            app:cornerRadius="28dp"
            app:strokeWidth="1dp"
            app:strokeColor="#40FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etTargetTvIp" />

        <TextView
            android:id="@+id/tvRemoteStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_status_disconnected"
            android:textColor="#4CAF50"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteEstop"
            app:layout_constraintEnd_toStartOf="@+id/btnLeaveRemote"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteEstop"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteEstop" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeaveRemote"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="6dp"
            app:icon="@drawable/mobile_hand_off_24"
            app:iconSize="24dp"
            app:iconTint="#D32F2F"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#00000000"
            app:cornerRadius="28dp"
            app:strokeWidth="2dp"
            app:strokeColor="#D32F2F"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteEstop" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainDpadContainer"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dpad_outer"
            android:backgroundTint="@color/pill_normal_inactive"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvRemoteStatus">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteOk"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="OK"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:maxLines="1"
                android:elevation="8dp"
                app:backgroundTint="#2196F3"
                app:cornerRadius="32dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteUp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▲"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="24dp"
                app:layout_constraintBottom_toTopOf="@+id/btnRemoteOk"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteDown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▼"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnRemoteOk"
                app:layout_constraintVertical_bias="0.4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteLeft"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="◀"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnRemoteOk"
                app:layout_constraintHorizontal_bias="0.6"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteRight"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▶"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.4"
                app:layout_constraintStart_toEndOf="@+id/btnRemoteOk"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteStream"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/media_link_24"
            app:iconSize="24dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="22dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoteLayout"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mainDpadContainer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteLayout"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/picture_in_picture_alt_24"
            app:iconSize="24dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="22dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteStream"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteStream"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteStream" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBar"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/credit_card_24"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="21dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/btnRemotePip"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnRemoteStream" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemotePip"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/subtitles_24"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#2196F3"
            app:cornerRadius="21dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteBar"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoteBox"
            app:layout_constraintHorizontal_weight="1.1"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteBar"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteBar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteBox"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/view_compact_alt_24"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="21dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/btnRemotePip"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteBar" />

        <TextView
            android:id="@+id/tvSecDpadTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="On-Screen Display OSD"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnRemoteBar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteZoomIn"
            android:layout_width="74dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/zoom_out_24"
            app:iconSize="20dp"
            app:iconTint="?android:attr/textColorPrimary"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/pill_normal_inactive"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSecDpadTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteHome"
            android:layout_width="74dp"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="6dp"
            app:icon="@drawable/home_app_logo_24"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="#E53935"
            app:cornerRadius="22dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnRemoteZoomIn" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/secDpadContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_dpad_outer"
            android:backgroundTint="@color/pill_normal_inactive"
            android:alpha="0.95"
            app:layout_constraintBottom_toBottomOf="@+id/btnRemoteHome"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoteZoomOut"
            app:layout_constraintStart_toEndOf="@+id/btnRemoteZoomIn"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteZoomIn">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecUp"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="▲"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="19dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecDown"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="▼"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="19dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginBottom="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecLeft"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="◀"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="19dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginStart="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoteSecRight"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="▶"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="11sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="4dp"
                app:backgroundTint="?android:attr/windowBackground"
                app:strokeWidth="1dp"
                app:strokeColor="?android:attr/textColorSecondary"
                app:cornerRadius="19dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginEnd="2dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteZoomOut"
            android:layout_width="74dp"
            android:layout_height="40dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/zoom_in_24"
            app:iconSize="20dp"
            app:iconTint="?android:attr/textColorPrimary"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/pill_normal_inactive"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteZoomIn" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoteCamera"
            android:layout_width="74dp"
            android:layout_height="44dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:elevation="4dp"
            app:icon="@drawable/developer_mode_tv_24"
            app:iconSize="22dp"
            app:iconTint="?android:attr/textColorPrimary"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/pill_normal_inactive"
            app:cornerRadius="22dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnRemoteHome" />

        <TextView
            android:id="@+id/tvFooterInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_pill_input"
            android:backgroundTint="@color/pill_normal_inactive"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/btnDummySpace"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/secDpadContainer" />

        <View
            android:id="@+id/btnDummySpace"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>