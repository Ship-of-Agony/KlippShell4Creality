<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/ivBackgroundWatermark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/nozzle"
        android:adjustViewBounds="true"
        android:alpha="0.08"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.75"
        android:importantForAccessibility="no" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="≡"
            android:textSize="32sp"
            android:backgroundTint="?android:attr/colorBackground"
            android:textColor="?android:attr/textColorPrimary"
            style="?android:attr/borderlessButtonStyle"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/ivAppHeaderLogo"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_app_header"
            android:contentDescription="@string/app_name"
            app:layout_constraintWidth_default="wrap"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constrainedWidth="true"
            android:layout_marginStart="64dp"
            android:layout_marginEnd="64dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:focusable="false"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:descendantFocusability="afterDescendants"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/btnExitApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/headerAddPrinter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center"
                    android:background="?android:attr/selectableItemBackground"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvAddPrinterTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_printer_down"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/containerAddPrinterForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etMainPrinterName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/printer_name_hint"
                        android:background="@drawable/bg_pill_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_marginBottom="12dp"
                        android:textSize="15sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:focusable="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clipChildren="false"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etMainPrinterIP"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/printer_ip_hint"
                            android:inputType="textUri"
                            android:background="@drawable/bg_pill_input"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="12dp"
                            android:layout_marginEnd="8dp"
                            android:textSize="15sp"
                            android:textColor="?android:attr/textColorPrimary"
                            android:focusable="true" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSystemSelect"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Port: 4408"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:cornerRadius="100dp"
                            android:backgroundTint="#424242"
                            android:textColor="#FFFFFF"
                            android:focusable="true" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etMainPrinterPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/printer_port_hint"
                        android:inputType="number"
                        android:background="@drawable/bg_pill_input"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_marginBottom="12dp"
                        android:textSize="15sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:visibility="gone"
                        android:focusable="true" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:layout_marginBottom="20dp">

                        <AutoCompleteTextView
                            android:id="@+id/actvMainPrinterModel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/printer_model_hint"
                            android:completionThreshold="1"
                            android:background="@drawable/bg_pill_input"
                            android:paddingStart="16dp"
                            android:paddingEnd="46dp"
                            android:paddingVertical="12dp"
                            android:textSize="15sp"
                            android:textColor="?android:attr/textColorPrimary"
                            android:focusable="true" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="16dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:alpha="0.5"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSearchNetwork"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_search_network"
                            android:backgroundTint="#2196F3"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="100dp"
                            android:paddingVertical="12dp"
                            android:layout_marginEnd="8dp"
                            android:focusable="true" />

                        <Button
                            android:id="@+id/btnAddMainPrinter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_add"
                            android:backgroundTint="#4CAF50"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="100dp"
                            android:paddingVertical="12dp"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/saved_printers"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvNoPrinter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_printers"
                android:gravity="center"
                android:padding="20dp"
                android:textStyle="italic" />

            <LinearLayout
                android:id="@+id/containerPrinters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnExitApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_exit"
        android:backgroundTint="#E53935"
        android:textColor="#FFFFFF"
        app:cornerRadius="100dp"
        android:paddingVertical="12dp"
        android:layout_marginTop="8dp"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Start-Animation / Schleier beim App-Kaltstart & Sprachwechsel -->
    <LinearLayout
        android:id="@+id/viewStartupVeil"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="24dp"
        android:clickable="false"
        android:focusable="false">

        <!-- Das runde Mipmap-Icon wurde hier restlos entfernt! -->

        <!-- Nur noch das perfekt skalierte KlippShell-Schriftlogo bleibt stehen -->
        <ImageView
            android:layout_width="220dp"
            android:layout_height="112dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_app_header"
            android:contentDescription="@string/app_name" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>