<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/ivBackgroundWatermark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/nozzle"
        android:adjustViewBounds="true"
        android:alpha="0.08"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.75"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingStart="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="≡"
            android:textSize="32sp"
            android:backgroundTint="?android:attr/colorBackground"
            android:textColor="?android:attr/textColorPrimary"
            style="?android:attr/borderlessButtonStyle"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/btnExitApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/headerAddPrinter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tvAddPrinterTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_printer_down"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/containerAddPrinterForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etMainPrinterName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/printer_name_hint"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="14dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etMainPrinterIP"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.65"
                            android:hint="@string/printer_ip_hint"
                            android:inputType="textUri"
                            android:background="@drawable/bg_input_rounded"
                            android:padding="14dp"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSystemSelect"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.35"
                            android:text="Creality\n(4408)"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            app:cornerRadius="12dp"
                            android:backgroundTint="#424242"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etMainPrinterPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/printer_port_hint"
                        android:inputType="number"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="14dp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone" />

                    <AutoCompleteTextView
                        android:id="@+id/actvMainPrinterModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/printer_model_hint"
                        android:completionThreshold="1"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="14dp"
                        android:layout_marginBottom="20dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSearchNetwork"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_search_network"
                            android:backgroundTint="#2196F3"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="24dp"
                            android:paddingVertical="12dp"
                            android:layout_marginEnd="8dp"/>

                        <Button
                            android:id="@+id/btnAddMainPrinter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_add"
                            android:backgroundTint="#4CAF50"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="24dp"
                            android:paddingVertical="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/saved_printers"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvNoPrinter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_printers"
                android:gravity="center"
                android:padding="20dp"
                android:textStyle="italic" />

            <LinearLayout
                android:id="@+id/containerPrinters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnExitApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_exit"
        android:backgroundTint="#E53935"
        android:textColor="#FFFFFF"
        app:cornerRadius="24dp"
        android:paddingVertical="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/viewStartupVeil"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="24dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>